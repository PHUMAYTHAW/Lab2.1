import statistics
def display_main_menu():
    print("Enter some numbers separated by commas (e.g. 5,67,32): ")

def get_user_input():
    user_input = input()
    string_list = user_input.split(",")
    float_list = [float(x.strip()) for x in string_list]
    return float_list

def calc_average_temperature(numbers):
    average = sum(numbers) / len(numbers)
    print("Average temperature:", average)
    return average

def calc_min_max_temperature(numbers):
    min_temperature = min(numbers)
    max_temperature = max(numbers)
    print("Minimum temperature:", min_temperature)
    print("Maximum temperature:", max_temperature)
    return min_temperature, max_temperature

def sorted_temperatures(numbers):
    sorted_numbers = sorted(numbers)
    print("Sorted temperatures:", sorted_numbers)
    return sorted_numbers 
  
def calc_median_temperature(numbers):
    median=statistics.median(numbers)
    print("Median temperature:", median)
    return median   

def main():
    display_main_menu()
    numbers = get_user_input()
    print("Numbers entered:", numbers)
    calc_average_temperature(numbers)
    calc_min_max_temperature(numbers)
    sorted_temperatures(numbers)
    calc_median_temperature(numbers)
    
if __name__ == "__main__":
    main()